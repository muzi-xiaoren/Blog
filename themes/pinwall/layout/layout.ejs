<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><% if (page.title) { %><%= page.title %> | <% } %><%= config.title %></title>
  <meta name="description" content="<%= page.description || config.description || '' %>">
  <link rel="stylesheet" href="<%- url_for('/css/main.css') %>">
</head>
<body class="<%= is_home() ? 'is-home' : 'is-sub' %>">

  <%# 全局水波纹 SVG 滤镜：JS 动态驱动 baseFrequency 与 scale 实现波动 %>
  <svg class="svg-defs" width="0" height="0" aria-hidden="true" focusable="false">
    <defs>
      <filter id="waterRipple" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence id="waterTurb" type="fractalNoise" baseFrequency="0.008 0.014" numOctaves="2" seed="3" result="noise"/>
        <feDisplacementMap id="waterDisp" in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G"/>
      </filter>
    </defs>
  </svg>

  <% if (!is_home()) { %>
  <header class="topbar">
    <a class="topbar-title" href="<%- url_for('/') %>"><%= config.title %></a>
    <nav class="topbar-nav">
      <% (theme.nav || []).forEach(function (item) { %>
        <a href="<%- url_for(item.url) %>"><%= item.title %></a>
      <% }) %>
    </nav>
  </header>
  <% } %>

  <%- body %>

  <footer class="site-footer">
    <span>© <%= new Date().getFullYear() %> <%= config.author %> · Powered by <a href="https://hexo.io" target="_blank" rel="noopener">Hexo</a> · Theme Pinwall</span>
  </footer>

  <script src="<%- url_for('/js/main.js') %>"></script>
</body>
</html>
